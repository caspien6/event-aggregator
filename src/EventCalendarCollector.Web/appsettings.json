{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Information"
    }
  },
  "AllowedHosts": "*",
  "GoogleCalendar": {
    "ServiceAccountFile": "xxx.json",
    "CalendarId": "<your-public-calendar-id>@group.calendar.google.com",
    "EventColors": {
      "A38": "Lavender",
      "BudapestPark": "Sage",
      "Kobuci": "Pumpkin"
    }
  },
  "EventCategories": {
    "Bolhás Macska": [ "hiperkarma", "Parno Graszt", "Fasza Kis Buli", "aurevoir", "Táncház", "Heaven Street Seven", "Csaknekedkislány" ],
    "Concert": [ "koncert", "live", "unplugged", "akusztikus" ],
    "Party": [ "party", "buli", "dj" ]
  },
  "Scrapers": {
    "A38": {
      "Enabled": true,
      "ProgramsUrl": "https://www.a38.hu/hu/programok",
      "CronSchedule": "0 */6 * * *"
    },
    "BudapestPark": {
      "Enabled": true,
      "ProgramsUrl": "https://www.budapestpark.hu/",
      "IncludedCategorySlugs": [ "esti-koncert", "nemzetkoezi-koncertek", "afterparty" ],
      "CronSchedule": "0 3-23/6 * * *"
    },
    "Kobuci": {
      "Enabled": true,
      "ProgramsUrl": "https://kobuci.hu/programok",
      "CronSchedule": "0 1-23/6 * * *"
    },
    "Britishmood": {
      "Enabled": true,
      "EventsUrl": "https://www.facebook.com/britishmoodofficial/upcoming_hosted_events",
      "UserAgent": "Googlebot/2.1 (+http://www.google.com/bot.html)",
      "CronSchedule": "0 2-23/6 * * *"
    }
  },
  "Hangfire": {
    "DashboardPath": "/hangfire"
  }
}
